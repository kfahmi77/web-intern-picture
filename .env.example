# Admin login (single password) — set a strong value in production
NUXT_ADMIN_PASSWORD=ganti-dengan-password-kuat

# S3-compatible / MinIO connection (used for images and photo metadata)
# Leave NUXT_MINIO_PORT empty for default HTTPS/HTTP ports.
NUXT_MINIO_END_POINT=localhost
NUXT_MINIO_PORT=9000
NUXT_MINIO_USE_SSL=false
NUXT_MINIO_ACCESS_KEY=minioadmin
NUXT_MINIO_SECRET_KEY=minioadmin
NUXT_MINIO_BUCKET=intern-memories
# Optional: only set true for local MinIO bootstrap. Keep false/empty on Vercel.
NUXT_MINIO_AUTO_CREATE_BUCKET=true
